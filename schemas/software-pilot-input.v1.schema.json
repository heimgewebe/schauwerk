{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.dev/schauwerk/software-pilot-input.v1.schema.json",
  "title": "Schauwerk generic software pilot input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "view_id",
    "sources",
    "title",
    "purpose",
    "components",
    "decisions",
    "roadmap",
    "work",
    "tests",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "const": "software-pilot-input.v1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "view_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "revision"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          },
          "revision": {
            "type": "string",
            "pattern": "^[0-9a-f]{40,64}$"
          }
        }
      }
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "components": {
      "$ref": "#/$defs/components"
    },
    "decisions": {
      "$ref": "#/$defs/decisions"
    },
    "roadmap": {
      "$ref": "#/$defs/roadmap"
    },
    "work": {
      "$ref": "#/$defs/work"
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "passed",
        "failed"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "risks": {
      "$ref": "#/$defs/risks"
    }
  },
  "$defs": {
    "baseItem": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/baseItem"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "responsibility",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              "title": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "responsibility": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              "status": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            }
          }
        ]
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "impact"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "impact": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "roadmap": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "outcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "outcome": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "work": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "status",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "severity": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "mitigation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    }
  }
}
