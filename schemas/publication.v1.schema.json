{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/schauwerk/publication.v1.schema.json",
  "title": "Schauwerk Publication v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "view_id",
    "status",
    "audience"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "view_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "published",
        "withdrawn",
        "expired"
      ]
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "source_revision": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
