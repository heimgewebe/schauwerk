{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/schauwerk/backup-manifest.v1.schema.json",
  "title": "Schauwerk Backup Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "created_at", "root_identity_digest", "entries", "secret_material_included", "copy_performed", "mutation_attempted", "manifest_digest"],
  "properties": {
    "schema_version": {"const": "schauwerk-backup-manifest.v1"},
    "created_at": {"type": "string", "format": "date-time"},
    "root_identity_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "entries": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "secret_material_included": {"const": false},
    "copy_performed": {"const": false},
    "mutation_attempted": {"const": false},
    "manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
