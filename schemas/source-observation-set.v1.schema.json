{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/schauwerk/source-observation-set.v1.schema.json",
  "title": "Schauwerk Source Observation Set v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "created_at", "observations", "counts", "usable_count", "mutation_attempted", "set_digest"],
  "properties": {
    "schema_version": {"const": "schauwerk-source-observation-set.v1"},
    "created_at": {"type": "string", "format": "date-time"},
    "observations": {"type": "array", "minItems": 1, "items": {"$ref": "source-observation.v1.schema.json"}},
    "counts": {"type": "object"},
    "usable_count": {"type": "integer", "minimum": 0},
    "mutation_attempted": {"const": false},
    "set_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
