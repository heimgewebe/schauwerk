        },
        "entrypoint": {
          "$ref": "#/$defs/fileName"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fileName"
          }
        },
        "metadata_fields": {
          "type": "array",
          "minItems": 5,
          "maxItems": 13,
          "uniqueItems": true,
          "items": {
            "enum": [
              "audience",
              "presentation_id",
              "presentation_version",
              "public_projection_sha256",
              "scene_order",
              "scene_order_sha256",
              "schema_version",
              "source_revision",
              "template",
              "variant_id",
              "variant_title",
              "visible_content_sha256",
              "visual_grammar"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "presentation_id"
              }
            },
            {
              "contains": {
                "const": "presentation_version"
              }
            },
            {
              "contains": {
                "const": "public_projection_sha256"
              }
            },
            {
              "contains": {
                "const": "source_revision"
              }
            },
            {
              "contains": {
                "const": "visible_content_sha256"
              }
            }
          ]
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/sourceDeclaration"
          }
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "published_at",
            "expires_at",
            "replaces_version",
            "expected_link_digest"
          ],
          "properties": {
