                {
                  "type": "null"
                }
              ]
            },
            "expected_link_digest": {
              "anyOf": [
                {
                  "$ref": "#/$defs/digest"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "declaration_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
