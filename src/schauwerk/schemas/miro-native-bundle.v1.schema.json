{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.example/schemas/miro-native-bundle.v1.schema.json",
  "title": "Schauwerk Miro native bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "operations"
  ],
  "properties": {
    "schema_version": {
      "const": "schauwerk-miro-native-bundle.v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/layout"
          },
          {
            "$ref": "#/$defs/diagram"
          },
          {
            "$ref": "#/$defs/document"
          },
          {
            "$ref": "#/$defs/table"
          },
          {
            "$ref": "#/$defs/code_widget"
          },
          {
            "$ref": "#/$defs/comment"
          }
        ]
      }
    }
  },
  "$defs": {
    "base": {
      "type": "object",
      "required": [
        "operation_id",
        "kind"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "kind": {
          "type": "string"
        },
        "target_miro_url": {
          "type": "string",
          "pattern": "^https://miro\\.com/app/board/"
        },
        "x": {
          "type": "number",
          "minimum": -1000000,
          "maximum": 1000000
        },
        "y": {
          "type": "number",
          "minimum": -1000000,
          "maximum": 1000000
        }
      }
    },
    "diagram": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "title",
            "diagram_type",
            "diagram_dsl"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "diagram"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "x": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "y": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "diagram_type": {
              "enum": [
                "flowchart",
                "uml_class",
                "uml_sequence",
                "entity_relationship"
              ]
            },
            "diagram_dsl": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200000
            }
          }
        }
      ]
    },
    "document": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "content"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "document"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "x": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "y": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "content": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80000
            }
          }
        }
      ]
    },
    "table_column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "column_type",
        "column_title"
      ],
      "properties": {
        "column_type": {
          "enum": [
            "text",
            "select",
            "date",
            "link",
            "person"
          ]
        },
        "column_title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "isTitle": {
          "type": "boolean"
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "displayValue",
              "color"
            ],
            "properties": {
              "displayValue": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "color": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              }
            }
          }
        }
      }
    },
    "table_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "columnTitle",
        "value"
      ],
      "properties": {
        "columnTitle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "value": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 5000
            },
            {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "string",
                "maxLength": 5000
              }
            },
            {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          ]
        }
      }
    },
    "table_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cells"
      ],
      "properties": {
        "rowId": {
          "type": "string",
          "pattern": "^[0-9a-zA-Z_-]{1,64}$"
        },
        "cells": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "$ref": "#/$defs/table_cell"
          }
        }
      }
    },
    "table_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout"
      ],
      "properties": {
        "layout": {
          "enum": [
            "table",
            "timeline",
            "kanban",
            "tree"
          ]
        },
        "view_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "group_by_column": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "table_nesting_enabled": {
          "type": "boolean"
        },
        "timeline_date_unit": {
          "enum": [
            "day",
            "week",
            "month",
            "quarter",
            "year"
          ]
        },
        "timeline_dependencies_enabled": {
          "type": "boolean"
        },
        "timeline_nesting_enabled": {
          "type": "boolean"
        },
        "timeline_start_date": {
          "type": "string"
        },
        "timeline_end_date": {
          "type": "string"
        },
        "tree_direction": {
          "enum": [
            "top_to_bottom",
            "left_to_right"
          ]
        }
      }
    },
    "table": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "table_title",
            "columns"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "table"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "x": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "y": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "table_title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "columns": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": {
                "$ref": "#/$defs/table_column"
              }
            },
            "rows": {
              "type": "array",
              "maxItems": 500,
              "items": {
                "$ref": "#/$defs/table_row"
              }
            },
            "view": {
              "$ref": "#/$defs/table_view"
            }
          }
        }
      ]
    },
    "code_widget": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "code"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "code_widget"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "x": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "y": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "code": {
              "type": "string",
              "minLength": 1,
              "maxLength": 6000
            },
            "language": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50
            },
            "title": {
              "type": "string",
              "maxLength": 100
            },
            "line_numbers_visible": {
              "type": "boolean"
            },
            "width": {
              "type": "number",
              "minimum": 256,
              "maximum": 10000
            }
          }
        }
      ]
    },
    "comment": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "content",
            "x",
            "y"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "comment"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "x": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "y": {
              "type": "number",
              "minimum": -1000000,
              "maximum": 1000000
            },
            "content": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2000
            }
          }
        }
      ]
    },
    "layout": {
      "allOf": [
        {
          "$ref": "#/$defs/base"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_id",
            "kind",
            "dsl"
          ],
          "properties": {
            "operation_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
            },
            "kind": {
              "const": "layout"
            },
            "target_miro_url": {
              "type": "string",
              "pattern": "^https://miro\\.com/app/board/"
            },
            "dsl": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50000
            }
          }
        }
      ]
    }
  }
}
