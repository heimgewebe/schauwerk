{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.org/schauwerk/schemas/representation-delivery-check.v1.schema.json",
  "title": "Schauwerk Representation Delivery Check v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "package_digest",
    "manifest_sha256",
    "input_digest",
    "plan_digest",
    "selected_formats",
    "native_bundle_available",
    "native_bundle_digest",
    "native_operation_count",
    "required_tools",
    "quality_score",
    "mutation_attempted",
    "does_not_establish"
  ],
  "properties": {
    "schema_version": {"const": "schauwerk-representation-delivery-check.v1"},
    "ok": {"const": true},
    "package_digest": {"$ref": "#/$defs/sha256"},
    "manifest_sha256": {"$ref": "#/$defs/sha256"},
    "input_digest": {"$ref": "#/$defs/sha256"},
    "plan_digest": {"$ref": "#/$defs/sha256"},
    "selected_formats": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["miro_native", "canvas", "document", "table", "mermaid"]}
    },
    "native_bundle_available": {"type": "boolean"},
    "native_bundle_digest": {
      "anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "native_operation_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "required_tools": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 100}
    },
    "quality_score": {
      "anyOf": [{"type": "integer", "minimum": 0, "maximum": 100}, {"type": "null"}]
    },
    "mutation_attempted": {"const": false},
    "does_not_establish": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 240}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
