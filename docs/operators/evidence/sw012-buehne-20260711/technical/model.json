  "presentation_id": "grabowski-operational-brief",
  "scenes": [
    {
      "duration_seconds": 90,
      "id": "orientation",
      "source_ids": [
        "primary",
        "guidance"
      ],
      "speaker_notes": [
        "Zuerst die Trennung von Vertrag und Beobachtung erklären."
      ],
      "title": "Grabowski als kontrollierter Operator",
      "visible": [
        {
          "items": [],
          "kind": "callout",
          "source_ids": [
            "primary"
          ],
          "text": "Der statische Vertrag beschreibt Fähigkeiten; wechselnde Laufzeitdaten bleiben getrennte Beobachtungen."
        }
      ]
    },
    {
      "duration_seconds": 120,
      "id": "authority",
      "source_ids": [
        "primary"
      ],
      "speaker_notes": [
        "Die drei Grenzen als Sicherheitsversprechen, nicht als Komfortfunktion markieren."
      ],
      "title": "Was ist hier verlässlich?",
      "visible": [
        {
          "items": [
            "Quellsysteme bleiben maßgeblich.",
            "Die Darstellung enthält keine Geheimnisse oder Rohkommandos.",
            "Keine Provider-Mutation wurde ausgeführt."
          ],
          "kind": "bullets",
          "source_ids": [
            "primary"
          ],
          "text": null
        }
      ]
    },
    {
      "duration_seconds": 150,
      "id": "channels",
      "source_ids": [
        "primary"
      ],
      "speaker_notes": [
        "Der Zustand stammt aus einer zeitgebundenen Fixture-Beobachtung und ist nicht live."
      ],
      "title": "Vier beobachtete Kanäle",
      "visible": [
        {
          "items": [
            "Hosts: teilweise verfügbar",
            "Runtime: teilweise verfügbar",
            "Aktuelle Arbeit: gesund",
            "Bekannte Lücken: gesund"
          ],
          "kind": "bullets",
          "source_ids": [
            "primary"
          ],
          "text": null
        }
      ]
    },
    {
      "duration_seconds": 120,
      "id": "degradation",
      "source_ids": [
        "primary"
      ],
      "speaker_notes": [
        "Die Degradierung als korrektes fail-closed Verhalten einordnen."
      ],
      "title": "Degradierung bleibt sichtbar",
      "visible": [
        {
          "items": [],
          "kind": "paragraph",
          "source_ids": [
            "primary"
          ],
          "text": "Ein unvollständiger Runtime-Kanal senkt den Gesamtzustand, ohne andere Diagnosepfade zu löschen."
        },
        {
          "items": [],
          "kind": "callout",
          "source_ids": [
            "primary"
          ],
          "text": "Provider- oder Kanalfehler dürfen lokale Evidenz nicht unsichtbar machen."
        }
      ]
    },
    {
      "duration_seconds": 120,
      "id": "close",
      "source_ids": [
        "primary",
        "guidance"
      ],
      "speaker_notes": [
        "Mit der praktischen Regel schließen: Beobachtung informiert, autorisiert aber keine Wirkung."
      ],
      "title": "Entscheidungsregel",
      "visible": [
        {
          "items": [
            "Quelle und Beobachtungszeit nennen.",
            "Partielle Zustände nicht zu gesund glätten.",
            "Wirkungen nur über einen aktuellen, gebundenen Gate-Vertrag auslösen."
          ],
          "kind": "bullets",
          "source_ids": [
            "primary"
          ],
          "text": null
        }
      ]
    }
  ],
